+/**
+ * STARFORGE TCG - Animated Cosmic Background
+ *
+ * Pure CSS animated background with slowly spiraling cosmic nebula swirls.
+ * Subtle, fluid, smooth — no static images needed.
+ */
+
+import React from 'react';
