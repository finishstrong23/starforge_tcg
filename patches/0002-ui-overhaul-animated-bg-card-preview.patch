+  .turn-timer .time-text {
+    font-size: 22px !important;
+  }
+}
+
+/* --- Full-screen menu/panel responsive --- */
+.screen-container {
+  width: 100%;
+  height: 100%;
+  overflow-y: auto;
+  -webkit-overflow-scrolling: touch;
+  padding: 20px;
+}
+
+@media (max-width: 768px) {
+  .screen-container {
+    padding: 12px;
+  }
+}
+
+@media (max-width: 480px) {
+  .screen-container {
+    padding: 8px;
+  }
+}
+
+/* --- Card grid responsive (Collection, Crafting) --- */
+.card-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
+  gap: 8px;
+}
+
+@media (max-width: 768px) {
+  .card-grid {
+    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
+    gap: 6px;
+  }
+}
+
+@media (max-width: 480px) {
+  .card-grid {
+    grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
+    gap: 4px;
+  }
+}
+
+/* --- Filter bar responsive (Collection, Crafting) --- */
+.filter-bar {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  align-items: center;
+}
+
+@media (max-width: 480px) {
+  .filter-bar {
+    gap: 4px;
+  }
+  .filter-bar button,
+  .filter-bar select,
+  .filter-bar input {
+    font-size: 11px !important;
+    padding: 4px 8px !important;
+    min-height: 36px;
+  }
+}
+
+/* --- Stats / achievement grids --- */
+.stat-grid {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 12px;
+}
+
+@media (max-width: 480px) {
+  .stat-grid {
+    grid-template-columns: repeat(2, 1fr);
+    gap: 8px;
+  }
+}
+
+/* --- Leaderboard/table responsive --- */
+.responsive-table {
+  width: 100%;
+  overflow-x: auto;
+  -webkit-overflow-scrolling: touch;
+}
+
+/* --- Modal/panel responsive (Daily, Settings) --- */
+.modal-panel {
+  max-width: 90vw;
+  max-height: 85vh;
+  overflow-y: auto;
+  -webkit-overflow-scrolling: touch;
+}
+
+@media (max-width: 480px) {
+  .modal-panel {
+    max-width: 95vw;
+    max-height: 90vh;
+    border-radius: 12px !important;
+  }
+}
+
+/* --- Campaign map planet touch targets --- */
+@media (hover: none) and (pointer: coarse) {
+  .planet-node {
+    min-width: 56px;
+    min-height: 56px;
+  }
+}
+
+/* --- Battle pass tier track horizontal scroll --- */
+.tier-track {
+  display: flex;
+  overflow-x: auto;
+  -webkit-overflow-scrolling: touch;
+  scroll-snap-type: x mandatory;
+  gap: 8px;
+  padding-bottom: 8px;
+}
+
+.tier-track > * {
+  scroll-snap-align: center;
+  flex-shrink: 0;
+}
+
+/* --- Meta dashboard matchup matrix scroll --- */
+@media (max-width: 768px) {
+  .matchup-matrix {
+    overflow-x: auto;
+    -webkit-overflow-scrolling: touch;
+  }
+}
