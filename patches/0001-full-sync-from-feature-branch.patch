+      fill="url(#go_gold)" stroke="#ffee88" strokeWidth="1.5" />
+    {/* Cup handles */}
+    <path d="M 30 32 Q 18 38 22 52 Q 24 58 32 56" fill="none" stroke="#cc9900" strokeWidth="3" strokeLinecap="round" />
