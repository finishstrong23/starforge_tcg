+/**
+ * STARFORGE TCG - Sound Manager
+ *
+ * Procedural audio engine using Web Audio API.
+ * All sounds are synthesized — no audio files needed.
+ * Supports mute toggle and volume control.
+ */
+
+type SoundName =
+  | 'cardPlay'
+  | 'cardDraw'
+  | 'attack'
+  | 'spellCast'
+  | 'minionDeath'
+  | 'heroDamage'
+  | 'heal'
