+          </button>
+        ) : achievement.claimed ? (
+          <span style={styles.claimedIcon}>✓</span>
+        ) : (
+          <span style={styles.rewardPreview}>{achievement.reward}g</span>
+        )}
+      </div>
+    </div>
+  );
+};
+
+const styles: Record<string, React.CSSProperties> = {
+  container: {
+    width: '100%', height: '100%', display: 'flex',
