+              setGameConfig({ playerRace: Race.COGSMITHS, aiDifficulty: diffMap[difficulty] || AIDifficulty.MEDIUM });
+              setScreen('game');
+            }}
+          />
+        </ScreenTransition>
+      )}
+
+      {/* Replay Viewer */}
+      {screen === 'replays' && (
+        <ScreenTransition screenKey="replays">
