+
+  return (
+    <div style={{
+      ...styles.questRow,
+      ...(isAnimating ? { animation: 'dp-claim-flash 0.4s ease-out' } : {}),
+    }}>
+      <div style={styles.questInfo}>
+        <span style={styles.questDesc}>{quest.description}</span>
+        <div style={styles.progressBarBg}>
+          <div style={{
+            ...styles.progressBarFill,
