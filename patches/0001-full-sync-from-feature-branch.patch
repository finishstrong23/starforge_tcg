+      {/* Tab Navigation */}
+      <div style={st.tabs}>
+        {(['map', 'standings', 'leaderboard'] as const).map(t => (
+          <button
+            key={t}
+            style={{
+              ...st.tab,
+              borderColor: tab === t ? '#ffd700' : 'transparent',
+              color: tab === t ? '#ffd700' : '#888',
+            }}
+            onClick={() => setTab(t)}
+          >
+            {t === 'map' ? 'Galactic Map' : t === 'standings' ? 'Standings' : 'Leaderboard'}
+          </button>
+        ))}
+      </div>
