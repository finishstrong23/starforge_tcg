+                </div>
+              </div>
+            </div>
+            <div style={styles.unlockPlaystyle}>
+              <span style={{ color: '#ffcc00' }}>Playstyle: </span>
+              {RaceData[opponentRace].playstyle}
+            </div>
+          </div>
+        )}
+
+        {/* Action buttons */}
+        <div style={{
+          ...styles.buttonRow,
+          opacity: phase >= 3 ? 1 : 0,
+        }}>
+          {!won && (
+            <button
+              style={{
+                ...styles.retryButton,
+                background: `linear-gradient(135deg, ${encounter.color} 0%, ${encounter.color}cc 100%)`,
+              }}
+              onClick={onRetry}
