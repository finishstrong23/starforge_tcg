+                opacity: validation.valid ? 1 : 0.4,
+                cursor: validation.valid ? 'pointer' : 'not-allowed',
+              }}
+              disabled={!validation.valid}
+              onClick={() => validation.valid && onConfirm(deckCardIds)}
+            >
