+    rules: ['Decks are swapped after mulligan', 'Build a deck for your enemy to play', 'All cards available'],
+    type: 'tavern_brawl',
+    rewards: [
+      { description: '150 Gold', requirement: 'Win 3 games', gold: 150 },
