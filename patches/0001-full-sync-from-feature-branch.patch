+    );
+  }
+
+  // Ghost orbs floating
+  const orbCount = 5 + detail * 2;
+  for (let i = 0; i < orbCount; i++) {
+    const ox = r(i * 3) * w;
+    const oy = r(i * 3 + 1) * h;
+    const orbR = 2 + r(i * 3 + 2) * (4 + detail * 2);
+
+    // Orb outer glow
+    els.push(
+      <circle key={`oglow${i}`} cx={ox} cy={oy} r={orbR * 2}
