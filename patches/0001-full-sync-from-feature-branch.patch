+          <div style={{ color: '#fff', fontSize: 18, fontWeight: 'bold' }}>{matchState.config.teamHealth} HP</div>
+          <div style={{ color: '#888', fontSize: 10 }}>
+            {RaceData[matchState.team2[0].race].name} + {RaceData[matchState.team2[1].race].name}
+          </div>
+        </div>
+      </div>
+
+      {/* Ping button */}
+      <button
