+    case 'checkout.session.completed': {
+      const sessionId = data.id as string;
+      await fulfillPurchase('stripe', sessionId);
+      break;
+    }
+    case 'charge.refunded': {
+      const chargeId = data.id as string;
+      await processRefund('stripe', chargeId);
+      break;
+    }
+  }
+}
