+    playerId: row.player_id,
+    productId: row.product_id,
+    provider: row.provider,
+    providerTransactionId: row.provider_transaction_id,
+    amountUsd: parseFloat(row.amount_usd),
+    currency: row.currency,
+    status: row.status,
+    createdAt: row.created_at,
