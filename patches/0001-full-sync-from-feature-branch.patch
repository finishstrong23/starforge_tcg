+const F_HERO = 'FRIENDLY_HERO';
+
+console.log('Generating 300 starter deck cards...\n');
+
+// ============================================================================
+// COGSMITHS — Industrial Mech Fortress (BARRIER/SWIFT/GUARDIAN/DRAIN)
