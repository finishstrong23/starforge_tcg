+    }
+    @keyframes vfx-death-particle {
+      0% { opacity: 1; transform: translate(0, 0) scale(1); }
+      70% { opacity: 0.5; }
+      100% { opacity: 0; transform: translate(var(--vfx-dx), var(--vfx-dy)) scale(0); }
